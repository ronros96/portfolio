{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@src/*": ["src/*"],
      "@layout/*": ["src/layout/*"],
      "@components/*": ["src/components/*"],
      "@hooks/*": ["src/hooks/*"],
      "@page/*": ["src/pages/*"],
      "@lib/*": ["src/lib/*"]
    }
  },
  "exclude": ["node_modules", "public"]
}
